# ============================================================
# .gitignore for microglia-morphology-profiling
# ============================================================

# --- Generated outputs --------------------------------------------------
# All figures and tables are regenerated by run_all.R; do not commit.
output/
*.html             # knitted Rmd reports
*.png              # figures
*.pdf              # figures (manuscript PDFs go elsewhere, not in repo)
*.svg

# --- Data ---------------------------------------------------------------
# Raw and intermediate data are archived on Zenodo / BioImage Archive,
# not on GitHub (see data/README.md).
data/*.csv
data/*.tif
data/*.tiff
data/raw_images/
data/ros_images/
data/filtered_images/
data/masks/
data/cellprofiler_output/

# Keep the data README (acts as placeholder)
!data/README.md

# --- R artifacts --------------------------------------------------------
.Rhistory
.RData
.Ruserdata
.Rapp.history
.Rproj.user/
*.Rcheck/

# renv (only commit the lockfile, not the library)
renv/library/
renv/staging/
renv/python/
renv/local/
renv/cellar/

# Keep these renv files (if you decide to use renv later)
!renv/activate.R
!renv/settings.json
!renv.lock

# Knitr / Rmd intermediate caches
*_cache/
*_files/
.knit.md

# --- Python artifacts ---------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
.conda/

# --- Frozen state anchor: KEEP THIS (it is part of the release) ----------
# Default rule below ignores all .rds files, but state_anchors.rds is
# explicitly preserved.
*.rds
!R/state_anchors.rds

# --- HPC / SLURM logs ---------------------------------------------------
*.out
*.err
slurm-*.out
preprocess_*.out
cellpose_*.out

# --- OS and editor cruft ------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*~

# --- Manuscript drafts (do NOT commit personal Word/Latex files) -------
*.docx
*.doc
*.tex
*.aux
*.log
*.bbl
*.blg

# --- Temporary / scratch files ------------------------------------------
tmp/
scratch/
*.tmp
*.bak
